# Database
DATABASE_URL="postgresql://sandbox:sandbox@localhost:5432/sandbox_dev"

# Auth (Better Auth)
BETTER_AUTH_SECRET="your-secret-here-change-in-production"
BETTER_AUTH_URL="http://localhost:3001"

# Server
NODE_ENV="development"

# Worker Mode (set to "false" to use real Azure workers)
USE_MOCK_WORKERS="true"

# Azure Integration (required when USE_MOCK_WORKERS=false)
AZURE_SUBSCRIPTION_ID=""
AZURE_RESOURCE_GROUP=""
CAJ_NAME=""
CAJ_WORKER_IMAGE=""
SESSION_POOL_ENDPOINT=""
BACKEND_CALLBACK_URL=""

# Azure OpenAI (required when USE_MOCK_WORKERS=false)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT_NAME=""
