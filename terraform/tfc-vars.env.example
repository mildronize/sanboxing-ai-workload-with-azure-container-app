# Terraform Cloud workspace variables
# Copy to tfc-vars.env and fill in real values.
# Used by: bun run terraform/scripts/setup-tfc-vars.ts

# --- Terraform Variables ---

location=southeastasia
resource_group_name=rg-sandbox-ai-demo
project_name=sandbox-ai-demo
azure_openai_endpoint=https://your-resource.openai.azure.com
azure_openai_api_key=REPLACE_ME
azure_openai_deployment_name=your-deployment-name
worker_image=ghcr.io/your-username/demo-worker:latest
backend_image=ghcr.io/your-username/demo-app:latest
backend_callback_url=https://your-ngrok-url.ngrok-free.app

# --- Environment Variables (Azure auth for TFC remote execution) ---

ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
